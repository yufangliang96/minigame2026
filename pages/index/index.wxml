<view class="home-container">
  <view class="game-title">
    <text class="title-text">万花筒·游境</text>
    <text class="subtitle-text">多重随机玩法小游戏</text>
  </view>
  
  <view class="start-button-area">
    <button class="start-button" bindtap="startGame">
      <text class="button-text">开始游戏</text>
    </button>
  </view>
  
  <view class="game-features">
    <view class="feature-item">
      <text class="feature-icon">[1]</text>
      <text class="feature-text">多重玩法</text>
    </view>
    <view class="feature-item">
      <text class="feature-icon">[2]</text>
      <text class="feature-text">随机挑战</text>
    </view>
    <view class="feature-item">
      <text class="feature-icon">[3]</text>
      <text class="feature-text">无限乐趣</text>
    </view>
  </view>
</view>